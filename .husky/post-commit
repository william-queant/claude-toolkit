#!/bin/sh

# Guard: recursion from our own amend
[ -n "$SKIP_POST_COMMIT" ] && exit 0

# Guard: rebase in progress
[ -d "$(git rev-parse --git-dir)/rebase-merge" ] && exit 0
[ -d "$(git rev-parse --git-dir)/rebase-apply" ] && exit 0

# Guard: cherry-pick in progress
[ -f "$(git rev-parse --git-dir)/CHERRY_PICK_HEAD" ] && exit 0

# Guard: merge commit (more than one parent)
[ "$(git rev-list --parents -1 HEAD | wc -w)" -gt 2 ] && exit 0

# Guard: amend detection — skip if user ran git commit --amend
# Compare current HEAD tree with the reflog entry before it;
# if the parent is the same, this is an amend of the previous commit
PREV_HEAD=$(git rev-parse 'HEAD@{1}' 2>/dev/null)
if [ -n "$PREV_HEAD" ]; then
  PREV_PARENT=$(git rev-parse "$PREV_HEAD^" 2>/dev/null)
  CURR_PARENT=$(git rev-parse "HEAD^" 2>/dev/null)
  if [ "$PREV_PARENT" = "$CURR_PARENT" ] && [ "$PREV_HEAD" != "$(git rev-parse HEAD)" ]; then
    exit 0
  fi
fi

# All guards passed — this is a fresh commit.
# Bump the version per Conventional Commits: the commit type names *why* the
# version changes, and the bump describes the compatibility impact to consumers.
#   feat                       -> minor (new, backward-compatible capability)
#   fix | perf                 -> patch (backward-compatible bug/perf fix)
#   <type>! / BREAKING CHANGE  -> major (breaking) — capped to minor while pre-1.0
#   docs|chore|style|refactor|test|ci|build, or non-conventional -> no release
MSG=$(git log -1 --pretty=%s)
BODY=$(git log -1 --pretty=%b)

node -e "
const fs = require('fs');
const subject = process.argv[1] || '';
const body = process.argv[2] || '';

const m = subject.match(/^(\w+)(\([^)]*\))?(!)?:/);
const type = m ? m[1] : '';
const breaking = (m && m[3]) || /BREAKING[ -]CHANGE/.test(body);

let kind;
if (breaking) kind = 'major';
else if (type === 'feat') kind = 'minor';
else if (type === 'fix' || type === 'perf') kind = 'patch';
else kind = null; // docs/chore/style/refactor/test/ci/build or non-conventional -> no release

if (!kind) process.exit(3);

const pkg = JSON.parse(fs.readFileSync('package.json', 'utf8'));
const parts = pkg.version.split('.').map(Number);
let maj = parts[0], min = parts[1], pat = parts[2];

// Pre-1.0: a breaking change bumps minor, never auto-crossing into 1.0.0.
if (kind === 'major' && maj === 0) kind = 'minor';

if (kind === 'major') { maj++; min = 0; pat = 0; }
else if (kind === 'minor') { min++; pat = 0; }
else { pat++; }
pkg.version = maj + '.' + min + '.' + pat;
fs.writeFileSync('package.json', JSON.stringify(pkg, null, '\t') + '\n');

const date = new Date().toISOString().split('T')[0];
const entry = '## ' + pkg.version + ' (' + date + ')\n\n- ' + subject + '\n';
const existing = fs.existsSync('CHANGELOG.md')
  ? fs.readFileSync('CHANGELOG.md', 'utf8').replace(/^# Changelog\n*/, '')
  : '';
fs.writeFileSync('CHANGELOG.md', '# Changelog\n\n' + entry + '\n' + existing);
" "$MSG" "$BODY"

status=$?
if [ "$status" -eq 0 ]; then
  # Amend the commit to include the version bump + changelog entry
  SKIP_POST_COMMIT=1 git add package.json CHANGELOG.md
  SKIP_POST_COMMIT=1 git commit --amend --no-edit --no-verify
elif [ "$status" -eq 3 ]; then
  : # no release-worthy change (docs/chore/etc.) — leave the version untouched
else
  echo "post-commit: version bump skipped (version script exited $status)" >&2
fi

exit 0
