#!/bin/sh

# Guard against recursion when amending
[ -n "$SKIP_POST_COMMIT" ] && exit 0

# Get commit info
MSG=$(git log -1 --pretty=%s)
DATE=$(date +%Y-%m-%d)

# Bump patch version in package.json
node -e "
const fs = require('fs');
const pkg = JSON.parse(fs.readFileSync('package.json', 'utf8'));
const v = pkg.version.split('.');
v[2] = Number(v[2]) + 1;
pkg.version = v.join('.');
fs.writeFileSync('package.json', JSON.stringify(pkg, null, '\t') + '\n');
console.log(pkg.version);
" > /tmp/ct-version.txt

VERSION=$(cat /tmp/ct-version.txt)
rm -f /tmp/ct-version.txt

# Prepend entry to CHANGELOG.md
ENTRY="## $VERSION ($DATE)\n\n- $MSG\n"
if [ -f CHANGELOG.md ]; then
  # Insert after the first line (# Changelog header)
  EXISTING=$(tail -n +2 CHANGELOG.md)
  printf "# Changelog\n\n$ENTRY\n$EXISTING" > CHANGELOG.md
else
  printf "# Changelog\n\n$ENTRY" > CHANGELOG.md
fi

# Amend commit to include version bump
SKIP_POST_COMMIT=1 git add package.json CHANGELOG.md
SKIP_POST_COMMIT=1 git commit --amend --no-edit --no-verify
