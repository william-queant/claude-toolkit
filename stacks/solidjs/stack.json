{
	"name": "ct-solidjs-patterns",
	"description": "SolidJS reactivity, components, and resource patterns",
	"defaultMappings": {
		"src/components": "ct-solidjs-patterns",
		"src/hooks": "ct-solidjs-patterns",
		"src/pages": "ct-solidjs-patterns"
	},
	"fileExtensions": ["tsx", "jsx"],
	"skillRules": {
		"ct-solidjs-patterns": {
			"description": "SolidJS reactivity, signals, effects, and component patterns",
			"priority": 8,
			"triggers": {
				"keywords": [
					"solid",
					"solidjs",
					"signal",
					"createSignal",
					"createEffect",
					"createMemo",
					"createResource",
					"Show",
					"For",
					"Switch",
					"Match"
				],
				"keywordPatterns": [
					"\\bcreateSignal\\b",
					"\\bcreateEffect\\b",
					"\\bcreateResource\\b",
					"\\bSolid\\b"
				],
				"pathPatterns": ["**/*.tsx", "**/*.jsx", "**/components/**"],
				"intentPatterns": [
					"(?:create|build|add).*(?:component|page|view)",
					"(?:reactive|signal|effect|memo)"
				],
				"contentPatterns": [
					"createSignal",
					"createEffect",
					"createMemo",
					"createResource",
					"<Show",
					"<For",
					"<Switch"
				]
			},
			"relatedSkills": [
				"ct-vanilla-extract-patterns",
				"ct-testing-patterns",
				"ct-vite-vitest-patterns",
				"ct-storybook-patterns",
				"ct-playwright-patterns"
			]
		}
	}
}
