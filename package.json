{
	"name": "claude-toolkit",
	"version": "0.11.0",
	"description": "Reusable Claude Code configuration toolkit with stack-specific connectors",
	"type": "module",
	"bin": {
		"claude-toolkit": "./bin/cli.ts"
	},
	"exports": {
		".": {
			"import": "./src/index.ts",
			"types": "./src/index.ts"
		}
	},
	"files": [
		"bin/",
		"src/",
		"core/",
		"stacks/",
		"templates/",
		"docs/",
		"CHANGELOG.md"
	],
	"scripts": {
		"typecheck": "tsc --noEmit",
		"lint": "biome check --write",
		"lint:check": "biome check",
		"test": "bun test",
		"postinstall": "bun bin/postinstall.mjs || node bin/postinstall.mjs || exit 0",
		"prepare": "npx husky"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,json,css}": "biome check --write --no-errors-on-unmatched"
	},
	"keywords": [
		"claude",
		"claude-code",
		"ai",
		"developer-tools",
		"configuration",
		"toolkit"
	],
	"author": "william-queant",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/william-queant/claude-toolkit.git"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@types/bun": "latest",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"typescript": "^6.0.2"
	},
	"engines": {
		"bun": ">=1.3.0"
	},
	"module": "src/index.ts"
}
