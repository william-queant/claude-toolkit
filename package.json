{
  "name": "claude-toolkit",
  "version": "0.1.0",
  "description": "Reusable Claude Code configuration toolkit with stack-specific connectors",
  "type": "module",
  "bin": {
    "claude-toolkit": "./bin/cli.ts"
  },
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "bin/",
    "src/",
    "core/",
    "stacks/",
    "templates/"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "developer-tools",
    "configuration",
    "toolkit"
  ],
  "author": "william-queant",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/william-queant/claude-toolkit.git"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.0"
  }
}
